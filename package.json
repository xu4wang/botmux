{
  "name": "botmux",
  "version": "0.0.0",
  "description": "Bridge between IM platforms and AI coding CLIs — one topic, one CLI session with live streaming",
  "type": "module",
  "main": "dist/index-daemon.js",
  "bin": {
    "botmux": "dist/cli.js"
  },
  "files": [
    "dist/",
    "ecosystem.config.cjs",
    "README.md",
    "README.en.md",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc && cp src/setup/lark-scopes.json dist/setup/ && pnpm dashboard:bundle && chmod +x dist/cli.js && node scripts/audit-dist.mjs",
    "dashboard:bundle": "node scripts/build-dashboard.mjs",
    "dashboard:watch": "node scripts/build-dashboard.mjs --watch",
    "daemon": "tsx src/index-daemon.ts",
    "daemon:start": "node dist/cli.js start",
    "daemon:stop": "node dist/cli.js stop",
    "daemon:restart": "node dist/cli.js restart",
    "daemon:logs": "node dist/cli.js logs",
    "daemon:status": "node dist/cli.js status",
    "use:here": "node scripts/claim-botmux-bin.mjs",
    "creds:sync": "node dist/cli.js suspend --isolated",
    "switch:here": "pnpm build && pnpm use:here",
    "test": "vitest run --project unit",
    "test:all": "vitest run",
    "test:e2e": "vitest run --project e2e",
    "test:bench": "tsx scripts/bench-tests.ts",
    "test:codex": "vitest run --project e2e test/codex-input.e2e.ts",
    "test:gemini": "vitest run --project e2e test/gemini-input.e2e.ts",
    "test:agy": "vitest run --project e2e test/agy-input.e2e.ts",
    "bench:resource": "node --expose-gc --import tsx scripts/bench-resource.ts",
    "test:e2e-browser:setup": "tsx test/e2e-browser/setup-login.ts",
    "test:e2e-browser": "tsx scripts/run-e2e.ts",
    "report:dashboard": "tsx scripts/report-dashboard.ts",
    "desktop:bundle": "esbuild src/desktop/main.ts --bundle --outfile=dist/desktop/main.cjs --platform=node --format=cjs --external:electron && esbuild src/desktop/preload.ts --bundle --outfile=dist/desktop/preload.cjs --platform=node --format=cjs --external:electron && esbuild src/desktop/renderer/app.ts --bundle --outfile=dist/desktop/renderer/app.js --platform=browser --format=iife && cp src/desktop/renderer/index.html dist/desktop/renderer/index.html && cp src/desktop/renderer/style.css dist/desktop/renderer/style.css",
    "desktop:smoke": "tsx scripts/desktop-smoke.ts",
    "desktop:install:local": "bash src/desktop/install-local.sh",
    "desktop:dev": "pnpm build && pnpm desktop:bundle && electron dist/desktop/main.cjs",
    "desktop:pack": "pnpm desktop:pack:local",
    "desktop:pack:local": "node scripts/desktop-pack-local.mjs",
    "prepublishOnly": "npm run build",
    "prepare": "git config core.hooksPath scripts/git-hooks 2>/dev/null || true"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.64.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/canvas": "^0.1.65",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/headless": "^6.0.0",
    "croner": "^10.0.1",
    "dotenv": "^17.3.1",
    "markdown-it": "^14.1.1",
    "node-pty": "^1.1.0",
    "pm2": "^6.0.0",
    "proxy-agent": "^6.5.0",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ws": "^8.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@midscene/web": "^1.7.6",
    "@playwright/test": "^1.58.2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-test-renderer": "19.1.0",
    "@types/ws": "^8.18.1",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.28.0",
    "memfs": "^4.57.1",
    "playwright": "^1.58.2",
    "react-test-renderer": "19.2.7",
    "tsx": "^4.20.5",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "node-pty"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.5.0",
  "license": "MIT"
}
